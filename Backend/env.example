# ─────────────────────────────────────────
#         TENORA — CONFIGURATION
# Copiez ce fichier en .env et remplissez
# les valeurs avant de lancer l'application
# ─────────────────────────────────────────

# ── BASE DE DONNÉES ───────────────────────
DATABASE_URL=mysql+pymysql://db_user:db_password@localhost/db_name

# ── SÉCURITÉ ──────────────────────────────
# Générer avec : python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=changez_cette_valeur_par_une_cle_aleatoire_longue

# ── APPLICATION ───────────────────────────
APP_NAME=Tenora
DEBUG=False
UPLOAD_FOLDER=uploads

# ── CORS ──────────────────────────────────
# URLs de votre frontend séparées par des virgules
ALLOWED_ORIGINS=["https://votredomaine.com","https://www.votredomaine.com"]

# ── MAILS (Resend) ────────────────────────
# Créer un compte sur https://resend.com
RESEND_API_KEY=re_votre_cle_api
MAIL_FROM=noreply@votredomaine.com

# ── WHATSAPP ──────────────────────────────
# Format international sans + (ex: 22796123456)
WHATSAPP_NUMBER=22796123456
